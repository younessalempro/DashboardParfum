# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=parfums
POSTGRES_PASSWORD=parfums
POSTGRES_DB=parfums
DATABASE_URL=postgresql+psycopg://parfums:parfums@postgres:5432/parfums

# Use this URL when running outside Docker (local Python, alembic, seed script):
# DATABASE_URL=postgresql+psycopg://parfums:parfums@localhost:5432/parfums

# ── API ───────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=change-me

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_USER_AGENT="Mozilla/5.0 (compatible; PerfumeWatch/0.1)"
SCRAPER_REQUEST_DELAY_MS=750
PLAYWRIGHT_HEADLESS=true
